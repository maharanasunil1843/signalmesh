# Copy to .env only if you want to use a real LLM instead of the deterministic mock.
# The project runs end-to-end with NEITHER of these set (mock is the default).

# LLM_PROVIDER=mock          # default; deterministic, no network, no key
# LLM_PROVIDER=openai        # uncomment to use OpenAI (requires the key below)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
